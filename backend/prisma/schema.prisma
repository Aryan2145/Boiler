generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contractor {
  id             String   @id @default(cuid())
  fullName       String
  licenseNo      String   @unique
  companyName    String
  companyAddress String
  telephone      String
  email          String   @unique
  passwordHash   String
  createdAt      DateTime @default(now())

  @@map("contractors")
}

enum GovtRole {
  ADMIN
  DIRECTOR
  DEPUTY_DIRECTOR
  ASSISTANT_DIRECTOR
}

model GovtUser {
  id           String   @id @default(cuid())
  name         String
  role         GovtRole
  phone        String
  email        String   @unique
  zone         String
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("govt_users")
}
